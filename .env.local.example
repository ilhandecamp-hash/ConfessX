# Copier ce fichier en .env.local et remplir avec vos valeurs Supabase
# (Dashboard Supabase > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Secret aléatoire utilisé pour hasher les fingerprints IP+UA.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FINGERPRINT_SECRET=change-me-to-a-long-random-string

# Mot de passe du panneau /admin (accès exclusif à toi pour modérer / purger).
# Générer un secret fort (pas un mot courant !) :
# node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_SECRET=change-me-too
